#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT=/home/ub/code/agent
PYTHON_BIN="${PYTHON_BIN:-python3}"

resolve() {
  PYTHONPATH="${REPO_ROOT}${PYTHONPATH:+:${PYTHONPATH}}" "${PYTHON_BIN}" -m agent.control_plane.address_resolver "$1"
}

APP_DIR="$(resolve uvicorn-app-dir)"
APP="$(resolve uvicorn-app)"
HOST="$(resolve uvicorn-host)"
PORT="$(resolve uvicorn-port)"
PATTERN="$(resolve uvicorn-pattern)"

start() {
  exec uvicorn --app-dir "$APP_DIR" "$APP" --host "$HOST" --port "$PORT" "$@"
}

stop() {
  pkill -f "$PATTERN"
}

status() {
  pgrep -af "$PATTERN" || true
}

cmd="${1:-start}"

case "$cmd" in
  start)
    if [ "$#" -gt 0 ]; then
      shift
    fi
    start "$@"
    ;;
  stop)
    stop
    ;;
  status)
    status
    ;;
  *)
    start "$@"
    ;;
esac
