#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HPC_SSH="${SCRIPT_DIR}/hpc_ssh.sh"

FRAN_REMOTE_ROOT="/data/EECS-LITQ/fran_storage"
FRAN_CONF_DIR="${FRAN_REMOTE_ROOT}/conf"
FRAN_CODE_ROOT="${FRAN_REMOTE_ROOT}/code"
FRAN_REPO_ROOT="${FRAN_CODE_ROOT}/fran"
LOCALISER_REPO_ROOT="${FRAN_CODE_ROOT}/localiser"
UTILZ_REPO_ROOT="${FRAN_CODE_ROOT}/utilz"
LABEL_ANALYSIS_REPO_ROOT="${FRAN_CODE_ROOT}/label_analysis"
REMOTE_PY="${FRAN_REPO_ROOT}/fran/run/dataregistry/update_datasources.py"

REMOTE_CMD="module load miniforge; source \"\$(conda info --base)/etc/profile.d/conda.sh\"; conda activate dl; export FRAN_CONF=${FRAN_CONF_DIR}; export PYTHONPATH=${LOCALISER_REPO_ROOT}:${FRAN_REPO_ROOT}:${UTILZ_REPO_ROOT}:${LABEL_ANALYSIS_REPO_ROOT}:\${PYTHONPATH:-}; export FRAN_STORE_LABEL_STATS=\${FRAN_STORE_LABEL_STATS:-0}; export FRAN_STORE_GIFS=\${FRAN_STORE_GIFS:-0}; python ${REMOTE_PY}"

for arg in "$@"; do
  printf -v quoted "%q" "${arg}"
  REMOTE_CMD+=" ${quoted}"
done

exec "${HPC_SSH}" "bash -lc $(printf "%q" "${REMOTE_CMD}")"
