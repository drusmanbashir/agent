#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
PYTHON_BIN="${PYTHON_BIN:-python3}"
STATE_DIR_DEFAULT="${HPC_DASHBOARD_STATE_DIR:-${HPC_LOGS_LOCAL_ROOT:-${HPC_JOBS_LOCAL_ROOT:-/s/agent_rw/hpc_logs}}/dashboard_service}"
STATE_DIR="${STATE_DIR_DEFAULT}"
PID_FILE="${STATE_DIR}/service.pid"
LOG_FILE="${STATE_DIR}/service.log"
META_FILE="${STATE_DIR}/service.meta"
SERVER_SCRIPT="${SCRIPT_DIR}/hpc_dashboard_web.py"
HOST="${HPC_DASHBOARD_HOST:-127.0.0.1}"
PORT="${HPC_DASHBOARD_PORT:-8765}"

usage() {
  cat <<'EOF'
Usage:
  hpc_dashboard_service start [--host HOST] [--port PORT] [--state-dir DIR]
  hpc_dashboard_service stop [--state-dir DIR]
  hpc_dashboard_service status [--state-dir DIR]
  hpc_dashboard_service url [--state-dir DIR]
EOF
}

meta_value() {
  local key="$1"
  [[ -f "${META_FILE}" ]] || return 1
  awk -F'=' -v k="${key}" '$1 == k { print substr($0, index($0, "=") + 1); exit }' "${META_FILE}"
}

pid_value() {
  [[ -f "${PID_FILE}" ]] || return 1
  tr -d '[:space:]' < "${PID_FILE}"
}

pid_running() {
  local pid
  pid="$(pid_value 2>/dev/null || true)"
  [[ -n "${pid}" ]] || return 1
  kill -0 "${pid}" 2>/dev/null
}

sync_paths() {
  PID_FILE="${STATE_DIR}/service.pid"
  LOG_FILE="${STATE_DIR}/service.log"
  META_FILE="${STATE_DIR}/service.meta"
}

healthcheck() {
  local url="$1"
  "${PYTHON_BIN}" -c 'import sys, urllib.request; urllib.request.urlopen(sys.argv[1] + "healthz", timeout=1).read()' "${url}" >/dev/null 2>&1
}

cleanup_stale() {
  if pid_running; then
    return 0
  fi
  rm -f "${PID_FILE}" "${META_FILE}"
}

cmd_start() {
  mkdir -p "${STATE_DIR}"
  cleanup_stale
  if pid_running; then
    local running_url
    running_url="$(meta_value url 2>/dev/null || true)"
    if [[ -n "${running_url}" ]] && healthcheck "${running_url}"; then
      printf '%s\n' "${running_url}"
      return 0
    fi
    echo "dashboard service is already running but not reporting a healthy URL" >&2
    return 1
  fi
  : > "${LOG_FILE}"
  rm -f "${META_FILE}"
  (
    cd "${REPO_ROOT}"
    "${SCRIPT_DIR}/job_registry.sh" archive 14 >> "${LOG_FILE}" 2>&1 || true
  )
  (
    cd "${REPO_ROOT}"
    setsid "${PYTHON_BIN}" "${SERVER_SCRIPT}" --host "${HOST}" --port "${PORT}" --state-dir "${STATE_DIR}" --meta-file "${META_FILE}" </dev/null >> "${LOG_FILE}" 2>&1 &
    echo $! > "${PID_FILE}"
  )

  local pid
  pid="$(pid_value)"
  local url=""
  for _ in $(seq 1 100); do
    if ! kill -0 "${pid}" 2>/dev/null; then
      echo "failed to start hpc dashboard service" >&2
      tail -n 40 "${LOG_FILE}" >&2 || true
      exit 1
    fi
    url="$(meta_value url 2>/dev/null || true)"
    if [[ -n "${url}" ]] && healthcheck "${url}"; then
      printf '%s\n' "${url}"
      return 0
    fi
    sleep 0.2
  done

  echo "dashboard service did not become responsive in time" >&2
  exit 1
}

cmd_stop() {
  if ! pid_running; then
    rm -f "${PID_FILE}" "${META_FILE}"
    echo "stopped"
    return 0
  fi
  local pid
  pid="$(pid_value)"
  kill "${pid}"
  for _ in $(seq 1 50); do
    if ! kill -0 "${pid}" 2>/dev/null; then
      rm -f "${PID_FILE}" "${META_FILE}"
      echo "stopped"
      return 0
    fi
    sleep 0.2
  done
  kill -9 "${pid}"
  rm -f "${PID_FILE}" "${META_FILE}"
  echo "stopped"
}

cmd_status() {
  cleanup_stale
  if ! pid_running; then
    echo "stopped"
    return 1
  fi
  local pid url
  pid="$(pid_value)"
  url="$(meta_value url 2>/dev/null || true)"
  if [[ -n "${url}" ]] && healthcheck "${url}"; then
    echo "running pid=${pid} url=${url}"
    return 0
  fi
  echo "running pid=${pid} url=${url:-unknown} health=unreachable"
  return 1
}

cmd_url() {
  cleanup_stale
  if ! pid_running; then
    echo "dashboard service is not running" >&2
    return 1
  fi
  local url
  url="$(meta_value url 2>/dev/null || true)"
  [[ -n "${url}" ]] || {
    echo "dashboard url is not available yet" >&2
    return 1
  }
  printf '%s\n' "${url}"
}

command_name="${1:-}"
[[ -n "${command_name}" ]] || {
  usage >&2
  exit 2
}
shift

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)
      HOST="$2"
      shift 2
      ;;
    --port)
      PORT="$2"
      shift 2
      ;;
    --state-dir)
      STATE_DIR="$2"
      sync_paths
      shift 2
      ;;
    -h|--help|help)
      usage
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

sync_paths

case "${command_name}" in
  start) cmd_start ;;
  stop) cmd_stop ;;
  status) cmd_status ;;
  url) cmd_url ;;
  *)
    echo "unknown command: ${command_name}" >&2
    usage >&2
    exit 2
    ;;
esac
