#!/usr/bin/env bash
set -euo pipefail

FRAN_JOBS_URL="${FRAN_JOBS_PAGE_URL:-http://127.0.0.1:8000/hpc/jobs}"
PYTHON_BIN="${PYTHON_BIN:-python3}"

usage() {
  cat <<'EOF'
Usage:
  hpc_dashboard_service start
  hpc_dashboard_service stop
  hpc_dashboard_service status
  hpc_dashboard_service url
EOF
}

healthcheck() {
  "${PYTHON_BIN}" -c 'import sys, urllib.request; urllib.request.urlopen(sys.argv[1], timeout=2).read()' "${FRAN_JOBS_URL}" >/dev/null 2>&1
}

cmd="${1:-}"
case "${cmd}" in
  start)
    printf '%s\n' "${FRAN_JOBS_URL}"
    ;;
  stop)
    echo "stopped"
    ;;
  status)
    if healthcheck; then
      echo "running url=${FRAN_JOBS_URL}"
      exit 0
    fi
    echo "stopped url=${FRAN_JOBS_URL}"
    exit 1
    ;;
  url)
    printf '%s\n' "${FRAN_JOBS_URL}"
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    echo "unknown command: ${cmd}" >&2
    usage >&2
    exit 2
    ;;
esac
