#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"

usage() {
  cat <<'EOF'
Usage:
  acp stdio

Starts the ACP MCP stdio server only when explicitly requested.
EOF
}

cd "${REPO_ROOT}"

case "${1-}" in
  stdio)
    shift
    exec python -m agent.control_plane.mcp_server "$@"
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    printf 'Unknown subcommand: %s\n\n' "$1" >&2
    usage >&2
    exit 2
    ;;
esac
